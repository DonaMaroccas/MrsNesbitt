      {
        "label": "Atualizar GitHub (Linux/Mac)",
        "type": "shell",
        "command": "${workspaceFolder}/update.sh",
        "linux": {
          "command": "${workspaceFolder}/update.sh"
        },
        "osx": {
          "command": "${workspaceFolder}/update.sh"
        },
        "problemMatcher": [],
        "group": {
          "kind": "build",
          "isDefault": true
        },
        "presentation": {
          "reveal": "always",
          "panel": "new"
        }
      }
    ]
}
