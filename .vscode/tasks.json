{
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Atualizar GitHub (Windows)",
        "type": "shell",
        "command": "${workspaceFolder}/update.bat",
        "windows": {
          "command": "${workspaceFolder}/update.bat"
        },
        "problemMatcher": [],
        "group": {
          "kind": "build",
